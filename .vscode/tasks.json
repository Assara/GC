{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build main",
      "type": "shell",
      "command": "clang++",
      "args": [
        "-std=c++23",
        "-O2",
        "-g",
        "-Wall",
        "-Wextra",
        "-Wpedantic",
        "-I.",
        "-IVectorSpace",
        "${workspaceFolder}/main.cpp",
        "-o",
        "${workspaceFolder}/output/main"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "build active cpp",
      "type": "shell",
      "command": "clang++",
      "args": [
        "-std=c++23",
        "-O2",
        "-g",
        "-Wall",
        "-Wextra",
        "-Wpedantic",
        "-I.",
        "-IVectorSpace",
        "${file}",
        "-o",
        "${workspaceFolder}/output/${fileBasenameNoExtension}"
      ],
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
